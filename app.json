{
  "expo": {
    "name": "Leaderboard Cache",
    "slug": "expo-leaderboard-redis-cache",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "leaderboardcache",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0B1220"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.phungnlg.leaderboardcache"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B1220"
      },
      "package": "com.phungnlg.leaderboardcache"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "tsconfigPaths": true
    }
  }
}
